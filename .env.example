# Core service configuration
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD='your_neo4j_password_here'

# Optional API auth keys (leave blank to disable auth)
RAG_API_KEY=
GATEWAY_API_KEY=

# Service URLs
RAG_API_URL=http://127.0.0.1:9010
GATEWAY_URL=http://127.0.0.1:9100
RAG_URL=http://127.0.0.1:9010

# ── Model Backend ──
# Switch between "openrouter" and "ngrok" by changing this single value:
MODEL_BACKEND=openrouter

# Option A: OpenRouter (cloud API, no server needed)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# Option B: ngrok / Local server (requires running notebook + tunnel)
MODEL_API_URL=https://your-ngrok-url.ngrok-free.app          
NGROK_AUTHTOKEN=

# Project and data paths
PROJECT=contacts-app
PROJECT_NAME=contacts-app
APP_NAME='contacts app'
SRS_PATH=./data/inputs/SRS1.txt
FIGMA_PATH=./data/inputs/GENERATED_JSON.json

# Generation and simulation tuning
TOP_K=8
SIM_ROUNDS=3
SIM_FAIL_EVERY=5

# Debug/reset toggles for simulator_runner.py
DEBUG_TRACE=0
RESET_TESTS_FIRST=0
RESET_ALL_FIRST=0

# ── Executor (Droidrun) config ──
GEMINI_API_KEY=your_gemini_api_key_here
EXECUTOR_LLM_PROVIDER=GoogleGenAI
EXECUTOR_LLM_MODEL=gemini-2.5-pro
EXECUTOR_TIMEOUT=120
EXECUTOR_ROUNDS=2
TARGET_APP_PACKAGE=com.android.contacts

# ── Live Logging (Better Stack / Logtail) ──
# Get your source token from: https://logs.betterstack.com → Sources → Python
LOGTAIL_SOURCE_TOKEN=your_logtail_source_token_here
